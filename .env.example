# URL base de tu AzuraCast (sin trailing slash)
AZURACASTURL=https://radio.kusmedios.lat

# API Key de AzuraCast
AZURACASTAPIKEY=xxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token para proteger el endpoint HTTP (solo modo HTTP/Render)
# Si está vacío, el endpoint es público
MCPAPITOKEN=

# Puerto (solo modo HTTP, Render lo inyecta automáticamente)
# PORT=10000
